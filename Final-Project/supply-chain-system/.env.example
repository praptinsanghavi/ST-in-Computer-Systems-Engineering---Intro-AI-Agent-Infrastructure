# Copy this file to .env and fill in your values
# The system works without OPENAI_API_KEY — MockLlmClient is used automatically

OPENAI_API_KEY=sk-your-key-here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=supplychain
POSTGRES_USER=sc_user
POSTGRES_PASSWORD=sc_pass
HTTP_PORT=8080

# Set to "real" to use actual OpenAI API, "mock" (default) for deterministic testing
LLM_MODE=mock
